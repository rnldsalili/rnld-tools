{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "rnld-tools-app",
  "compatibility_date": "2025-09-02",
  "compatibility_flags": ["nodejs_compat"],
  "main": "@tanstack/react-start/server-entry",
  "env": {
    "production": {
      "name": "rnld-tools-app",
      "routes": [
        {
          "pattern": "tools.ronald.it.com",
          "custom_domain": true
        }
      ]
    }
  }
}
