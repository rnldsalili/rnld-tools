{
  "name": "@workspace/api",
  "type": "module",
  "scripts": {
    "dev": "bun run cf-typegen && wrangler dev",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "db:generate": "bunx --bun prisma generate",
    "typecheck": "bun run cf-typegen && tsc --noEmit"
  },
  "exports": {
    "./routes": "./src/routes/index.ts",
    "./auth": "./src/lib/auth.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1004.0",
    "@aws-sdk/s3-request-presigner": "^3.1004.0",
    "@hono/zod-validator": "^0.7.6",
    "@prisma/adapter-d1": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@workspace/constants": "workspace:*",
    "better-auth": "^1.5.4",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "hono": "^4.12.5",
    "hono-rate-limiter": "^0.5.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "eslint": "^10.0.3",
    "@types/node": "^25.3.5",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prisma": "^7.4.2",
    "typescript": "^5.9.3",
    "wrangler": "^4.71.0"
  }
}
