generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  runtime  = "workerd"
}

datasource db {
  provider = "sqlite"
}

enum ClientStatus {
  ENABLED
  DISABLED
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  userRoles     UserRole[]

  loansCreated            Loan[]             @relation("LoanCreatedBy")
  loansUpdated            Loan[]             @relation("LoanUpdatedBy")
  clientsCreated          Client[]           @relation("ClientCreatedBy")
  clientsUpdated          Client[]           @relation("ClientUpdatedBy")
  loanInstallmentsCreated LoanInstallment[]  @relation("LoanInstallmentCreatedBy")
  loanInstallmentsUpdated LoanInstallment[]  @relation("LoanInstallmentUpdatedBy")
  loanDocumentLogs        LoanDocumentLog[]  @relation("LoanDocumentLogActorUser")
  notificationLogsQueued  NotificationLog[]  @relation("NotificationLogQueuedByUser")

  @@unique([email])
  @@map("user")
}

model Role {
  id          String           @id @default(cuid())
  slug        String           @unique
  name        String
  description String?
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
  userRoles   UserRole[]

  @@map("role")
}

model RolePermission {
  id     String @id @default(cuid())
  roleId String
  module String
  action String

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, module, action])
  @@index([roleId])
  @@map("role_permission")
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_role")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

enum LoanInstallmentStatus {
  PENDING
  PAID
  OVERDUE
}

enum DocumentType {
  LOAN
}

enum NotificationChannel {
  EMAIL
  SMS
}

enum NotificationEmailProvider {
  BREVO
}

enum NotificationSmsProvider {
  PHILSMS
  SEMAPHORE
}

enum NotificationEvent {
  LOAN_CREATED
  INSTALLMENT_DUE_REMINDER
  INSTALLMENT_OVERDUE_REMINDER
  INSTALLMENT_PAID
}

enum NotificationContentFormat {
  RICH_TEXT_JSON
  PLAIN_TEXT
}

enum NotificationLogStatus {
  QUEUED
  PROCESSING
  RETRYING
  SENT
  FAILED
}

enum LoanDocumentLogEventType {
  LINK_CREATED
  LINK_REVOKED
  LINK_VIEWED
  LINK_ACCESS_INVALID_OR_EXPIRED
  DOCUMENT_SIGNED
  SIGN_ATTEMPT_INVALID_OR_EXPIRED
  SIGN_ATTEMPT_DUPLICATE
  SIGN_ATTEMPT_MISSING_SIGNATURE
}

enum LoanDocumentLogActorType {
  AUTHENTICATED_USER
  PUBLIC_LINK_VISITOR
}

model Loan {
  id                  String   @id @default(cuid())
  clientId            String
  amount              Float
  currency            String   @default("PHP")
  interestRate        Float?
  description         String?
  installmentInterval String
  loanDate            DateTime
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdByUserId     String
  updatedByUserId     String

  client           Client             @relation(fields: [clientId], references: [id], onDelete: Restrict)
  createdBy        User               @relation("LoanCreatedBy", fields: [createdByUserId], references: [id])
  updatedBy        User               @relation("LoanUpdatedBy", fields: [updatedByUserId], references: [id])
  installments     LoanInstallment[]
  documents        LoanDocument[]
  loanDocumentLogs LoanDocumentLog[]

  @@index([clientId])
  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@map("loan")
}

model Client {
  id              String       @id @default(cuid())
  name            String
  phone           String?
  email           String?
  address         String?
  status          ClientStatus @default(ENABLED)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  createdByUserId String
  updatedByUserId String

  createdBy User   @relation("ClientCreatedBy", fields: [createdByUserId], references: [id])
  updatedBy User   @relation("ClientUpdatedBy", fields: [updatedByUserId], references: [id])
  loans     Loan[]

  @@index([status])
  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@map("client")
}

model LoanInstallment {
  id              String                @id @default(cuid())
  loanId          String
  dueDate         DateTime
  amount          Float
  status          LoanInstallmentStatus @default(PENDING)
  paidAt          DateTime?
  remarks         String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  createdByUserId String
  updatedByUserId String

  loan      Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)
  createdBy User @relation("LoanInstallmentCreatedBy", fields: [createdByUserId], references: [id])
  updatedBy User @relation("LoanInstallmentUpdatedBy", fields: [updatedByUserId], references: [id])

  @@index([loanId])
  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@map("loan_installment")
}

model Document {
  id                String       @id @default(cuid())
  type              DocumentType
  name              String
  description       String?
  content           String
  linkExpiryDays    Int          @default(7)
  requiresSignature Boolean      @default(true)
  loanDocuments     LoanDocument[]
  loanDocumentLogs  LoanDocumentLog[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([type])
  @@map("document")
}

model NotificationTemplate {
  id                  String                    @id @default(cuid())
  channel             NotificationChannel
  name                String
  description         String?
  subject             String?
  content             String
  contentFormat       NotificationContentFormat
  notificationConfigs NotificationEventConfig[]
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  @@index([channel])
  @@map("notification_template")
}

model NotificationEventConfig {
  id            String                    @id @default(cuid())
  event         NotificationEvent
  channel       NotificationChannel
  emailProvider NotificationEmailProvider?
  smsProvider   NotificationSmsProvider?
  templateId    String
  isEnabled     Boolean                   @default(false)
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  template NotificationTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)

  @@unique([event, channel])
  @@index([templateId])
  @@index([channel])
  @@map("notification_event_config")
}

model NotificationLog {
  id               String                    @id @default(cuid())
  channel          NotificationChannel
  event            NotificationEvent?
  status           NotificationLogStatus     @default(QUEUED)
  isTestSend       Boolean                   @default(false)
  emailProvider    NotificationEmailProvider?
  smsProvider      NotificationSmsProvider?
  recipientEmail   String?
  recipientName    String?
  recipientPhone   String?
  subject          String?
  messageContent   String
  attemptCount     Int                       @default(0)
  lastErrorMessage String?
  queuedAt         DateTime
  lastAttemptAt    DateTime?
  sentAt           DateTime?
  failedAt         DateTime?
  queuedByUserId   String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  queuedByUser User? @relation("NotificationLogQueuedByUser", fields: [queuedByUserId], references: [id], onDelete: SetNull)

  @@index([channel, queuedAt])
  @@index([event, queuedAt])
  @@index([status, queuedAt])
  @@index([queuedByUserId])
  @@map("notification_log")
}

model LoanDocument {
  id                  String    @id @default(cuid())
  loanId              String
  templateId          String
  signedAt            DateTime?
  signatureKey        String?
  contentSnapshotHtml String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  loan             Loan              @relation(fields: [loanId], references: [id], onDelete: Cascade)
  template         Document          @relation(fields: [templateId], references: [id], onDelete: Cascade)
  loanDocumentLogs LoanDocumentLog[]

  @@unique([loanId, templateId])
  @@index([loanId])
  @@index([templateId])
  @@map("loan_document")
}

model LoanDocumentLog {
  id             String                   @id @default(cuid())
  loanId         String
  templateId     String
  loanDocumentId String?
  token          String?
  eventType      LoanDocumentLogEventType
  actorType      LoanDocumentLogActorType
  actorUserId    String?
  ipAddress      String?
  userAgent      String?
  eventData      String?
  createdAt      DateTime                 @default(now())

  loan         Loan          @relation(fields: [loanId], references: [id], onDelete: Cascade)
  template     Document      @relation(fields: [templateId], references: [id], onDelete: Cascade)
  loanDocument LoanDocument? @relation(fields: [loanDocumentId], references: [id], onDelete: SetNull)
  actorUser    User?         @relation("LoanDocumentLogActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([loanId, createdAt])
  @@index([templateId, createdAt])
  @@index([loanDocumentId])
  @@index([token])
  @@index([actorUserId])
  @@map("loan_document_log")
}
